# Discord User Token (REQUIRED for relay bot)
# Get this from Discord developer tools or browser localStorage
# This is your user account token for Group DM access
DISCORD_USER_TOKEN=your_user_token_here

# Ollama Configuration (these are fine as-is for Docker)
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=bazobehram/qwen3-14b-claude-4.5-opus-high-reasoning
RELAY_TIMEOUT_MS=120000
HISTORY_MAX_MESSAGES=5

# ComfyUI Configuration
COMFYUI_URL=http://host.docker.internal:8188

# Health endpoint port
HEALTH_PORT=3001

# Bot owner ID (optional, for permissions)
DISCORD_OWNER_ID=your_discord_user_id
